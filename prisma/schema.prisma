generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verification")
}

model Institucion {
  id          Int      @id @default(autoincrement())
  cct         String   @unique
  nombre      String
  estado      String
  zonaEscolar String   @map("zona_escolar")
  urlLogo     String?  @map("url_logo")

  equipos       Equipo[]        
  alumnos       Alumno[] 
  personalApoyo PersonalApoyo[]

  @@map("instituciones")
}


/// ENUMS 
enum Genero {
  MASCULINO
  FEMENINO
  OTRO
}

enum Estatus {
  ACTIVO
  INACTIVO
}

enum TipoDisciplina {
  DEPORTIVA
  CULTURAL
}

enum Categoria {
  FEMENIL
  VARONIL
  UNICA
}

enum Modalidad {
  INDIVIDUAL
  EQUIPO
}

/// ===============================
/// MODELOS
/// ===============================



model Alumno {
  id               Int @id @default(autoincrement())
  institucionId    Int
  tutorId          Int?
  clave            String?
  estado           String?
  semestre         Int?
  curp             String
  matricula        String
  nombres          String
  apellidoPaterno  String
  apellidoMaterno  String
  fechaNacimiento  DateTime
  genero           Genero
  fotoUrl          String?
  estatus          Estatus
  alergias         String?
  tipoSangre       String? @map("tipo_sangre")
  padecimientos    String?
  medicamentos     String?
  contactoEmergenciaNombre   String? @map("contacto_emergencia_nombre")
  contactoEmergenciaTelefono String? @map("contacto_emergencia_telefono")
  docCurp                  Boolean @default(false) @map("doc_curp")
  docComprobanteEstudios   Boolean @default(false) @map("doc_comprobante_estudios")
  docCartaResponsiva       Boolean @default(false) @map("doc_carta_responsiva")
  docCertificadoMedico     Boolean @default(false) @map("doc_certificado_medico")
  docIneTutor              Boolean @default(false) @map("doc_ine_tutor")

  institucion Institucion @relation(fields: [institucionId], references: [id])
  tutor       Tutor?      @relation(fields: [tutorId], references: [id])
  inscripciones Inscripcion[]

  @@map("alumnos")
}

model Tutor {
  id             Int    @id @default(autoincrement())
  nombreCompleto String @map("nombre_completo")
  parentesco     String
  telefono       String
  email          String?
  direccion      String?

  alumnos Alumno[]

  @@map("tutores")
}

model Disciplina {
  id             Int @id @default(autoincrement())
  nombre         String
  tipo           TipoDisciplina
  categoria      Categoria
  modalidad      Modalidad
  minIntegrantes Int @map("min_integrantes")
  maxIntegrantes Int @map("max_integrantes")

  equipos      Equipo[]
  inscripciones Inscripcion[]   

  @@map("disciplinas")
}


model Equipo {
  id            Int     @id @default(autoincrement())
  disciplinaId  Int     @map("id_disciplina")
  institucionId Int     @map("id_institucion")
  nombreEquipo  String  @map("nombre_equipo")
  folioRegistro String  @map("folio_registro")

  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])
  institucion   Institucion @relation(fields: [institucionId], references: [id])
  inscripciones Inscripcion[]

  @@map("equipos")
}

model Inscripcion {
  id             Int      @id @default(autoincrement())
  alumnoId       Int      @map("id_alumno")
  disciplinaId   Int      @map("id_disciplina") 
  equipoId       Int      @map("id_equipo")
  fechaRegistro  DateTime @map("fecha_registro")
  esTitular      Boolean  @map("es_titular")

  alumno       Alumno     @relation(fields: [alumnoId], references: [id])
  equipo        Equipo       @relation(fields: [equipoId], references: [id])
  disciplina    Disciplina  @relation(fields: [disciplinaId], references: [id])

  @@map("inscripciones")
}

model PersonalApoyo {
  id                        Int     @id @default(autoincrement())
  institucionId             Int
  curp                      String
  nombres                   String
  apellidoPaterno           String
  apellidoMaterno           String
  puesto                    String
  telefono                  String
  email                     String?
  contactoEmergenciaNombre  String? @map("contacto_emergencia_nombre")
  contactoEmergenciaTelefono String? @map("contacto_emergencia_telefono")
  docCurp                   Boolean @default(false) @map("doc_curp")
  docIdentificacionOficial  Boolean @default(false) @map("doc_identificacion_oficial")
  docComprobanteDomicilio   Boolean @default(false) @map("doc_comprobante_domicilio")
  docCartaAntecedentes      Boolean @default(false) @map("doc_carta_antecedentes")
  estatus                   Estatus

  institucion Institucion @relation(fields: [institucionId], references: [id])

  @@map("personal_apoyo")
}


